# The development machine's global ~/.npmrc sets workspaces=true, which would
# exclude the workspace ROOT from npm install (devDependencies silently
# skipped). Pinning include-workspace-root repairs that without forcing
# workspace mode onto every npm command (a repo-level workspaces=true breaks
# tools that run `npm config get`, e.g. actions/setup-node's cache step).
include-workspace-root=true

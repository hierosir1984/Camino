# The development machine's global ~/.npmrc sets workspaces=true, which excludes
# the workspace ROOT from installs (root devDependencies silently skipped).
# include-workspace-root repairs that while keeping workspace linking (the
# @camino/* symlinks) intact. Do NOT set workspaces=false here: it stops the
# fan-out but also disables linking. The zero-quota spike command therefore
# invokes the vitest binary directly (see spikes/dispatch/README.md), bypassing
# npm's global-config workspace fan-out.
include-workspace-root=true

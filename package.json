{
  "name": "camino",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first mission control plane for autonomous software development",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "eslint . && prettier --check . && tsc -b && vitest run",
    "spike:test": "vitest run spikes",
    "spike:dispatch": "node --import tsx spikes/dispatch/run.ts",
    "spike:plan-probe": "node --import tsx spikes/plan-probe/run.ts",
    "spike:plan-probe:check": "node --import tsx spikes/plan-probe/check-packet.ts",
    "spike:quarantine": "vitest run spikes/quarantine",
    "spike:untrusted": "node --import tsx spikes/untrusted-content/run.ts",
    "spike:untrusted:check": "node --import tsx spikes/untrusted-content/check-findings.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.0.0"
  }
}

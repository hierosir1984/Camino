{
  "name": "camino",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first mission control plane for autonomous software development",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -b",
    "unit": "vitest run",
    "test": "npm run lint && npm run typecheck && npm run unit",
    "gate": "node scripts/check-prereqs.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.0.0"
  }
}
